<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Premium Gradient Squircle Background -->
    <path android:pathData="M 2,12 C 2,5.5 5.5,2 12,2 C 18.5,2 22,5.5 22,12 C 22,18.5 18.5,22 12,22 C 5.5,22 2,18.5 2,12 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="2" android:startY="2"
                android:endX="22" android:endY="22">
                <item android:color="#0052D4" android:offset="0.0" />
                <item android:color="#4364F7" android:offset="0.5" />
                <item android:color="#6FB1FC" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Glassmorphic Inset Squircle -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.08"
        android:pathData="M 3.5,12 C 3.5,6.5 6.5,3.5 12,3.5 C 17.5,3.5 20.5,6.5 20.5,12 C 20.5,17.5 17.5,20.5 12,20.5 C 6.5,20.5 3.5,17.5 3.5,12 Z" />

    <!-- Location Pin Shadow -->
    <group
        android:pivotX="12"
        android:pivotY="12"
        android:scaleX="0.72"
        android:scaleY="0.72"
        android:translateX="0.4"
        android:translateY="0.8">
        <path
            android:fillColor="#000000"
            android:fillAlpha="0.15"
            android:pathData="M12,3 C8.1,3 5,6.1 5,10 C5,15.5 12,21 12,21 C12,21 19,15.5 19,10 C19,6.1 15.9,3 12,3 Z" />
    </group>

    <!-- Location Pin (Solid White) -->
    <group
        android:pivotX="12"
        android:pivotY="12"
        android:scaleX="0.72"
        android:scaleY="0.72">
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M12,3 C8.1,3 5,6.1 5,10 C5,15.5 12,21 12,21 C12,21 19,15.5 19,10 C19,6.1 15.9,3 12,3 Z" />
    </group>

    <!-- Airplane Shadow -->
    <group
        android:pivotX="12"
        android:pivotY="12"
        android:scaleX="0.45"
        android:scaleY="0.45"
        android:rotation="45"
        android:translateX="0.4"
        android:translateY="-0.2">
        <path
            android:fillColor="#000000"
            android:fillAlpha="0.2"
            android:pathData="M12,2 C11.5,2 11,2.5 11,3 L11,9 L2,13 L2,15 L11,13 L11,19 L8,21 L8,22.5 L12,21.5 L16,22.5 L16,21 L13,19 L13,13 L22,15 L22,13 L13,9 L13,3 C13,2.5 12.5,2 12,2 Z" />
    </group>

    <!-- Airplane (Vibrant Orange-to-Red Gradient Jet) -->
    <group
        android:pivotX="12"
        android:pivotY="12"
        android:scaleX="0.45"
        android:scaleY="0.45"
        android:rotation="45"
        android:translateY="-1.0">
        <path
            android:pathData="M12,2 C11.5,2 11,2.5 11,3 L11,9 L2,13 L2,15 L11,13 L11,19 L8,21 L8,22.5 L12,21.5 L16,22.5 L16,21 L13,19 L13,13 L22,15 L22,13 L13,9 L13,3 C13,2.5 12.5,2 12,2 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:type="linear"
                    android:startX="12" android:startY="2"
                    android:endX="12" android:endY="22.5">
                    <item android:color="#FF8C00" android:offset="0.0" />
                    <item android:color="#FF3D00" android:offset="1.0" />
                </gradient>
            </aapt:attr>
        </path>
    </group>

</vector>
