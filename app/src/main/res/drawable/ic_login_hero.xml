<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="240dp"
    android:height="120dp"
    android:viewportWidth="120"
    android:viewportHeight="60">

    <!-- Soft Gradient Sky Background -->
    <path android:pathData="M 0,0 H 120 V 60 H 0 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0" android:startY="0"
                android:endX="0" android:endY="60">
                <item android:color="#E6F0FF" android:offset="0.0" />
                <item android:color="#FFFFFF" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Sun / Globe Graphic -->
    <path
        android:fillAlpha="0.4"
        android:pathData="M 60,12 A 18,18 0 1,1 59.9,12 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="42" android:startY="12"
                android:endX="78" android:endY="48">
                <item android:color="#B2D4FF" android:offset="0.0" />
                <item android:color="#FFFFFF" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Cloud 1 (Left Background) -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.75"
        android:pathData="M 15,20 C 15,17 17,15 20,15 C 21,15 22,15.5 23,16 C 24,14 26,13 28,13 C 31,13 33,15 33,18 C 33,18.5 33,18.8 32.8,19 C 34,19.5 35,20.5 35,22 C 35,24 33,26 31,26 H 19 C 17,26 15,24 15,22 Z" />

    <!-- Cloud 2 (Right Background) -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.75"
        android:pathData="M 85,15 C 85,12 87,10 90,10 C 91,10 92,10.5 93,11 C 94,9 96,8 98,8 C 101,8 103,10 103,13 C 103,13.5 103,13.8 102.8,14 C 104,14.5 105,15.5 105,17 C 105,19 103,21 101,21 H 89 C 87,21 85,19 85,17 Z" />

    <!-- Back Mountain -->
    <path
        android:fillColor="#D8E7FC"
        android:pathData="M 15,55 L 45,25 L 75,55 Z" />

    <!-- Front Mountain -->
    <path
        android:fillColor="#B7D3FC"
        android:pathData="M 40,55 L 65,30 L 90,55 Z" />

    <!-- Ground Horizontal Line -->
    <path
        android:strokeColor="#A0C2F9"
        android:strokeWidth="1"
        android:pathData="M 5,55 H 115" />

    <!-- Location Pin on Front Mountain Peak -->
    <group
        android:translateX="65"
        android:translateY="30"
        android:scaleX="0.4"
        android:scaleY="0.4"
        android:pivotX="12"
        android:pivotY="21">
        <!-- Pin Shadow -->
        <path
            android:fillColor="#1A000000"
            android:pathData="M 12,2 C 8,2 5,5 5,9 C 5,14 12,20 12,20 C 12,20 19,14 19,9 C 19,5 16,2 12,2 Z"
            android:translateX="0.8"
            android:translateY="0.8" />
        <!-- Pin Base (Coral Red) -->
        <path
            android:fillColor="#FF3D00"
            android:pathData="M 12,2 C 8.1,2 5,5.1 5,9 C 5,14.3 12,20 12,20 C 12,20 19,14.3 19,9 C 19,5.1 15.9,2 12,2 Z" />
        <!-- Inner White Circle -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M 12,6 A 3,3 0 1,1 11.9,6 Z" />
    </group>

    <!-- Flight Path Trail (Dashed Curved Line) -->
    <path
        android:strokeColor="#FF8C00"
        android:strokeWidth="1.2"
        android:pathData="M 10,48 Q 52,10 98,28" />

    <!-- Airplane Jet at the end of the Curve -->
    <group
        android:translateX="98"
        android:translateY="28"
        android:scaleX="0.22"
        android:scaleY="0.22"
        android:rotation="22"
        android:pivotX="12"
        android:pivotY="12">
        <!-- Shadow -->
        <path
            android:fillColor="#26000000"
            android:pathData="M12,2 C11.5,2 11,2.5 11,3 L11,9 L2,13 L2,15 L11,13 L11,19 L8,21 L8,22.5 L12,21.5 L16,22.5 L16,21 L13,19 L13,13 L22,15 L22,13 L13,9 L13,3 C13,2.5 12.5,2 12,2 Z"
            android:translateX="1.0"
            android:translateY="1.0" />
        <!-- Airplane Body (Primary Blue) -->
        <path
            android:fillColor="#0056D2"
            android:pathData="M12,2 C11.5,2 11,2.5 11,3 L11,9 L2,13 L2,15 L11,13 L11,19 L8,21 L8,22.5 L12,21.5 L16,22.5 L16,21 L13,19 L13,13 L22,15 L22,13 L13,9 L13,3 C13,2.5 12.5,2 12,2 Z" />
    </group>

</vector>
