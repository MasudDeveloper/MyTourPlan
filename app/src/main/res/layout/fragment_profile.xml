<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="100dp"
        android:gravity="center_horizontal">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">
            
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="explore TourPlanner"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/primaryColor"/>
                
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                app:srcCompat="@android:drawable/ic_menu_search"
                app:tint="@color/textColorPrimary"
                android:layout_marginEnd="16dp"/>
                
            <androidx.cardview.widget.CardView
                android:layout_width="32dp"
                android:layout_height="32dp"
                app:cardCornerRadius="16dp">
                <ImageView
                    android:id="@+id/ivProfileTop"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="#CCCCCC"/>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Profile Info -->
        <androidx.cardview.widget.CardView
            android:layout_width="100dp"
            android:layout_height="100dp"
            app:cardCornerRadius="50dp"
            android:layout_marginBottom="16dp">
            <ImageView
                android:id="@+id/ivProfileLarge"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="#FFCC80"/>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvUserName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Name"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/textColorPrimary"/>
            
        <TextView
            android:id="@+id/tvUserEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="email@example.com"
            android:textSize="14sp"
            android:textColor="@color/textColorMuted"
            android:layout_marginBottom="16dp"/>
            
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Premium Member"
                android:textSize="10sp"
                android:textColor="@color/primaryColor"
                android:background="#E3F2FD"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:layout_marginEnd="8dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Explorer Level 5"
                android:textSize="10sp"
                android:textColor="#E65100"
                android:background="#FFE0B2"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"/>
        </LinearLayout>

        <!-- Sections -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Account Settings"
            android:textColor="@color/primaryColor"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>
            
        <com.google.android.material.card.MaterialCardView
            style="@style/CardStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:id="@+id/tvEditProfile" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Edit Profile" android:textSize="14sp" android:textColor="@color/textColorPrimary" android:drawablePadding="16dp" android:paddingVertical="8dp"/>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginVertical="8dp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Change Password" android:textSize="14sp" android:textColor="@color/textColorPrimary" android:drawablePadding="16dp" android:paddingVertical="8dp"/>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginVertical="8dp"/>
                <LinearLayout android:id="@+id/llManualSync" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="8dp">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/stat_notify_sync" app:tint="@color/primaryColor" android:layout_marginEnd="16dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Manual Sync" android:textSize="14sp" android:textColor="@color/textColorPrimary"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="160dp"
            android:layout_height="wrap_content"
            android:text="Log Out"
            app:cornerRadius="20dp"
            android:textColor="@color/dangerColor"
            android:backgroundTint="#FFEBEE"
            app:iconTint="@color/dangerColor"
            app:icon="@android:drawable/ic_lock_power_off"
            app:iconGravity="textStart"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
