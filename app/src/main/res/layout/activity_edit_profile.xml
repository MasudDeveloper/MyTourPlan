<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA">

    <!-- Top AppBar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:navigationIcon="@android:drawable/ic_menu_revert"
        app:title="Edit Profile"
        app:titleTextColor="#000000" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">
            
            <!-- Profile Image Section -->
            <FrameLayout
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    app:cardCornerRadius="60dp"
                    app:cardElevation="0dp">
                    <ImageView
                        android:id="@+id/ivEditProfilePic"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_camera"
                        android:background="#E0E0E0" />
                </androidx.cardview.widget.CardView>
                
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/bg_circle_camera"
                    android:padding="6dp"
                    android:src="@android:drawable/ic_menu_camera"
                    app:tint="#FFFFFF" />
            </FrameLayout>
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Change Profile Photo"
                android:textColor="#0056D2"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="32dp" />

            <!-- Full Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Full Name"
                android:textColor="#333333"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />
            <com.google.android.material.textfield.TextInputLayout
                style="@style/ProfileInputStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                app:startIconTint="#999999"
                android:layout_marginBottom="20dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etProfileName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#333333"
                    android:inputType="textPersonName" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Email Address -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email Address"
                android:textColor="#333333"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />
            <com.google.android.material.textfield.TextInputLayout
                style="@style/ProfileInputStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:startIconDrawable="@android:drawable/ic_dialog_email"
                app:startIconTint="#999999"
                android:layout_marginBottom="20dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etProfileEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#333333"
                    android:enabled="false"
                    android:inputType="textEmailAddress" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Phone Number -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phone Number"
                android:textColor="#333333"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">
                
                <TextView
                    android:layout_width="70dp"
                    android:layout_height="match_parent"
                    android:text="+880"
                    android:textColor="#333333"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:background="@drawable/bg_country_code"
                    android:layout_marginEnd="12dp" />
                
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/ProfileInputStyle"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    app:startIconDrawable="@android:drawable/ic_menu_call"
                    app:startIconTint="#999999">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etProfilePhone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#333333"
                        android:inputType="phone" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Travel Bio -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Travel Bio"
                android:textColor="#333333"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />
            <com.google.android.material.textfield.TextInputLayout
                style="@style/ProfileInputStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:startIconDrawable="@android:drawable/ic_menu_info_details"
                app:startIconTint="#999999"
                android:layout_marginBottom="32dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTravelBio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minLines="3"
                    android:gravity="top|start"
                    android:textColor="#333333"
                    android:inputType="textMultiLine" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Save Changes Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveProfile"
                style="@style/ButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Save Changes"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:icon="@android:drawable/ic_menu_save"
                app:iconGravity="textStart"
                android:layout_marginBottom="32dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
