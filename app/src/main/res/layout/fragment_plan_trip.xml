<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="100dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Plan Your Next Adventure"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/textColorPrimary"
            android:layout_marginBottom="8dp"/>
            
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Click the button below to manually plan your next trip."
            android:textSize="14sp"
            android:textColor="@color/textColorMuted"
            android:layout_marginBottom="24dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="180dp"
            app:cardCornerRadius="16dp"
            android:layout_marginBottom="24dp">
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#0083B0">
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/secondaryColor"
                    app:cardCornerRadius="8dp"
                    android:layout_gravity="bottom|start"
                    android:layout_margin="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="New Destinations"
                        android:textColor="@color/surfaceColor"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"/>
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>



        <!-- Create Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGeneratePlan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Create My Tour Plan ✨"
            android:paddingVertical="16dp"
            app:cornerRadius="12dp"
            android:layout_marginTop="16dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
