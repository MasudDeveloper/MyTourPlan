<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/surfaceColor"
    app:cardCornerRadius="16dp"
    android:layout_marginBottom="12dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E2E8F0"
    app:cardElevation="2dp">
    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">
        
        <!-- Header Info (Initials, Name, Due/Refund) -->
        <LinearLayout 
            android:layout_width="match_parent" 
            android:layout_height="wrap_content" 
            android:orientation="horizontal" 
            android:gravity="center_vertical" 
            android:layout_marginBottom="12dp">
            
            <TextView 
                android:id="@+id/tvInitials" 
                android:layout_width="40dp" 
                android:layout_height="40dp" 
                android:text="MB" 
                android:textColor="@color/white"
                android:background="@drawable/bg_icon_primary" 
                android:gravity="center" 
                android:textStyle="bold" 
                android:textSize="16sp"
                android:layout_marginEnd="12dp"/>
                
            <LinearLayout 
                android:layout_width="0dp" 
                android:layout_height="wrap_content" 
                android:layout_weight="1"
                android:orientation="vertical">
                
                <TextView 
                    android:id="@+id/tvName" 
                    android:layout_width="wrap_content" 
                    android:layout_height="wrap_content" 
                    android:text="Member Name" 
                    android:textColor="@color/textColorPrimary" 
                    android:textSize="16sp" 
                    android:textStyle="bold"/>
                    
                <TextView 
                    android:id="@+id/tvPaidMethod" 
                    android:layout_width="wrap_content" 
                    android:layout_height="wrap_content" 
                    android:text="Paid: ৳0 (Cash)" 
                    android:textColor="@color/textColorMuted" 
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <TextView 
                android:id="@+id/tvDueRefund" 
                android:layout_width="wrap_content" 
                android:layout_height="wrap_content" 
                android:text="Due: ৳0" 
                android:textSize="14sp" 
                android:textStyle="bold" 
                android:textColor="#DC2626"/>
        </LinearLayout>
        
        <!-- Progress Info -->
        <LinearLayout 
            android:layout_width="match_parent" 
            android:layout_height="wrap_content" 
            android:orientation="horizontal"
            android:layout_marginTop="4dp">
            
            <TextView 
                android:id="@+id/tvProgressLabel" 
                android:layout_width="0dp" 
                android:layout_height="wrap_content" 
                android:layout_weight="1" 
                android:text="বাজেট পূরণ পরিস্থিতি" 
                android:textSize="11sp" 
                android:textColor="@color/textColorMuted"/>
                
            <TextView 
                android:id="@+id/tvPercentage" 
                android:layout_width="wrap_content" 
                android:layout_height="wrap_content" 
                android:text="0%" 
                android:textSize="11sp" 
                android:textStyle="bold"
                android:textColor="@color/primaryColor"/>
        </LinearLayout>
        
        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:progress="0"
            android:progressTint="@color/primaryColor"
            android:progressBackgroundTint="#F1F5F9"
            android:layout_marginTop="6dp"/>
            
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
