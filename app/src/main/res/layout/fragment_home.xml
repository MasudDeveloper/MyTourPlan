<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="100dp">

        <!-- Top Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                app:srcCompat="@drawable/ic_plan_trip"
                app:tint="@color/primaryColor"/>
                
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="TourPlanner"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/primaryColor"
                android:layout_marginStart="8dp"/>
                
            <ImageView
                android:id="@+id/ivSyncStatus"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/stat_notify_sync"
                app:tint="@color/primaryColor"
                android:layout_marginEnd="16dp"
                android:visibility="gone"/>
                
            <androidx.cardview.widget.CardView
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:cardCornerRadius="20dp">
                <ImageView
                    android:id="@+id/ivProfileTop"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="#CCCCCC"/>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome back, Alex"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/textColorPrimary"
            android:layout_marginBottom="24dp"/>

        <!-- Hero Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="220dp"
            app:cardCornerRadius="16dp"
            android:layout_marginBottom="24dp">
            
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                
                <ImageView
                    android:id="@+id/ivHeroImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="#2E4A35"/>
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="bottom">
                    
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/secondaryColor"
                        app:cardCornerRadius="8dp"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NEW ADVENTURE"
                            android:textColor="@color/surfaceColor"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"/>
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Plan a New Trip"
                        android:textColor="@color/surfaceColor"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>
                        
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Our AI-powered navigator is ready to build your perfect custom itinerary in seconds."
                        android:textColor="#E0E0E0"
                        android:textSize="12sp"
                        android:layout_marginBottom="16dp"/>
                        
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStartPlanning"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Start Planning"
                        app:cornerRadius="20dp"
                        android:backgroundTint="#B86A14" />
                </LinearLayout>
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 2x2 Grid -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2"
            android:layout_marginBottom="24dp">
            
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvMyTrips"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F0F3F8"
                android:clickable="true"
                android:focusable="true">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" app:srcCompat="@drawable/ic_my_trips" app:tint="@color/primaryColor" android:layout_marginBottom="8dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="My Trips" android:textColor="@color/textColorPrimary" android:textSize="12sp" android:textStyle="bold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvExplore"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F0F3F8"
                android:clickable="true"
                android:focusable="true">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" app:srcCompat="@drawable/ic_plan_trip" app:tint="@color/primaryColor" android:layout_marginBottom="8dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Explore" android:textColor="@color/textColorPrimary" android:textSize="12sp" android:textStyle="bold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F0F3F8">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" app:srcCompat="@drawable/ic_home" app:tint="@color/primaryColor" android:layout_marginBottom="8dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bookings" android:textColor="@color/textColorPrimary" android:textSize="12sp" android:textStyle="bold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvSaved"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F0F3F8"
                android:clickable="true"
                android:focusable="true">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" app:srcCompat="@drawable/ic_profile" app:tint="@color/primaryColor" android:layout_marginBottom="8dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Saved" android:textColor="@color/textColorPrimary" android:textSize="12sp" android:textStyle="bold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </GridLayout>

        <!-- Upcoming Trip -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Upcoming Trip" android:textSize="20sp" android:textStyle="bold" android:textColor="@color/textColorPrimary"/>
            <TextView android:id="@+id/tvViewAllUpcoming" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="View All" android:textSize="14sp" android:textColor="@color/primaryColor" android:textStyle="bold"/>
        </LinearLayout>
        
        <com.google.android.material.card.MaterialCardView
            style="@style/CardStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="120dp" app:cardCornerRadius="12dp" android:layout_marginBottom="16dp">
                    <ImageView android:id="@+id/ivUpcomingTrip" android:scaleType="centerCrop" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#4CAF50"/>
                </androidx.cardview.widget.CardView>
                
                <TextView android:id="@+id/tvUpcomingDest" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Sylhet Weekend" android:textSize="22sp" android:textStyle="bold" android:textColor="@color/textColorPrimary" android:gravity="center"/>
                <TextView android:id="@+id/tvUpcomingDates" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Oct 24 - Oct 27, 2023 • 3 Days" android:textSize="12sp" android:textColor="@color/textColorMuted" android:gravity="center" android:layout_marginBottom="12dp"/>
                
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hotels Confirmed" android:textSize="10sp" android:textColor="@color/successColor" android:background="#E8F5E9" android:paddingHorizontal="8dp" android:paddingVertical="4dp" android:layout_marginEnd="8dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="In Progress" android:textSize="10sp" android:textColor="#E65100" android:background="#FFF3E0" android:paddingHorizontal="8dp" android:paddingVertical="4dp"/>
                </LinearLayout>
                
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginBottom="12dp"/>
                
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TIME" android:textSize="10sp" android:textColor="@color/textColorMuted" android:textStyle="bold"/>
                        <TextView android:id="@+id/tvUpcomingTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--:--" android:textSize="14sp" android:textColor="@color/primaryColor" android:textStyle="bold"/>
                    </LinearLayout>
                    <View android:layout_width="1dp" android:layout_height="30dp" android:background="#EEEEEE"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MEMBERS" android:textSize="10sp" android:textColor="@color/textColorMuted" android:textStyle="bold"/>
                        <TextView android:id="@+id/tvUpcomingMembers" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="14sp" android:textColor="@color/textColorPrimary" android:textStyle="bold"/>
                    </LinearLayout>
                    <View android:layout_width="1dp" android:layout_height="30dp" android:background="#EEEEEE"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BUDGET" android:textSize="10sp" android:textColor="@color/textColorMuted" android:textStyle="bold"/>
                        <TextView android:id="@+id/tvUpcomingBudget" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="৳0.00" android:textSize="14sp" android:textColor="@color/textColorPrimary" android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
